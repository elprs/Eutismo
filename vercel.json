{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/teacher", "destination": "/teacher/" },
    { "source": "/display", "destination": "/display/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
